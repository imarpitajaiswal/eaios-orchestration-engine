# 1. Environment Variables & Secrets (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
credentials.json

# 2. Python / Backend (FastAPI, LangGraph)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
.env_python

# 3. Node.js / Frontend (Next.js)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/
build/

# 4. OS / IDE specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 5. Vector DB / Local Data Volumes
qdrant_data/
redis_data/
postgres_data/